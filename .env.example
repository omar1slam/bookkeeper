# Telegram Bot API token from BotFather (rotate the exposed one before deploy)
TELEGRAM_TOKEN=

# Random string; passed to setWebhook as secret_token and verified per request
TELEGRAM_WEBHOOK_SECRET=

# LLM provider routing: "anthropic" (default) or "gemini"
LLM_PROVIDER=anthropic

# Anthropic config (used when LLM_PROVIDER=anthropic) — rotate the exposed key
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Gemini config (used when LLM_PROVIDER=gemini)
GEMINI_API_KEY=

# Full service-account JSON on a single line
GOOGLE_SERVICE_ACCOUNT_JSON= bookkeeper-bot@bookkeeper-500214.iam.gserviceaccount.com

# Google Sheet ID (the budget workbook)
SHEET_ID=1R2ltmQQTC120yBxX_GHjQKOlImvWy_Cq-XUBnFjBIUI

# Comma-separated allowed Telegram chat IDs (leave empty on first run to bootstrap)
ALLOWED_CHAT_ID=

# Defaults
DEFAULT_TZ=Africa/Cairo
DEFAULT_CURRENCY=EGP
